        result = []
        for hotel in v:
            if isinstance(hotel, dict):
                # Create HotelSuggestion with defaults for missing fields
                result.append(HotelSuggestion(**hotel))
            elif isinstance(hotel, HotelSuggestion):
                result.append(hotel)
        return result
    
    @field_validator("flights", mode="before")
